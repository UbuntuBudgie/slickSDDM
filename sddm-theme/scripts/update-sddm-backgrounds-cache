#!/bin/bash
# update-sddm-backgrounds-cache - Read AccountsService wallpapers and embed in theme
# Part of ubuntu-budgie-login SDDM theme AccountsService integration

set -euo pipefail

THEME_DIR="/usr/share/sddm/themes/ubuntu-budgie-login"
COMPONENTS_DIR="$THEME_DIR/components"
CACHE_DIR="$THEME_DIR/cache"
CACHE_FILE="$CACHE_DIR/user-backgrounds.json"
QML_FILE="$COMPONENTS_DIR/AccountsService.qml"
ACCOUNTS_DIR="/var/lib/AccountsService/users"

# Create cache directory if needed
mkdir -p "$CACHE_DIR"

# Start building JSON cache
echo "{" > "$CACHE_FILE"
first=true

# Read each user's AccountsService file
if [ -d "$ACCOUNTS_DIR" ]; then
    for user_file in "$ACCOUNTS_DIR"/*; do
        [ -f "$user_file" ] || continue
        
        username=$(basename "$user_file")
        
        # Skip system users
        case "$username" in
            sddm|lightdm|gdm|nobody|root) continue ;;
        esac
        
        # Extract BackgroundFile and strip quotes
        background=$(grep -E "^BackgroundFile=" "$user_file" 2>/dev/null | cut -d= -f2- | tr -d '\r\n' | sed 's/^[[:space:]]*//;s/[[:space:]]*$//' || echo "")
        background=$(echo "$background" | sed "s/^['\"]//;s/['\"]$//")
        
        # Only include if file exists
        if [ -n "$background" ] && [ -f "$background" ]; then
            if [ "$first" = false ]; then
                echo "," >> "$CACHE_FILE"
            fi
            echo -n "  \"$username\": \"$background\"" >> "$CACHE_FILE"
            first=false
        fi
    done
fi

echo "" >> "$CACHE_FILE"
echo "}" >> "$CACHE_FILE"

# Read cache content and escape for QML embedding
CACHE_CONTENT=$(cat "$CACHE_FILE")
CACHE_ESCAPED=$(echo "$CACHE_CONTENT" | sed 's/\\/\\\\/g' | sed 's/"/\\"/g' | tr '\n' ' ')

# Generate AccountsService.qml with embedded cache data
cat > "$QML_FILE" << 'EOF'
pragma Singleton
import QtQuick

QtObject {
    // This data is auto-generated by update-sddm-backgrounds-cache
    // DO NOT EDIT THIS FILE MANUALLY - it will be overwritten
    readonly property string embeddedCacheData: "CACHE_DATA_PLACEHOLDER"
    
    property var userBackgrounds: ({})
    property bool cacheLoaded: false
    
    Component.onCompleted: {
        loadEmbeddedCache()
    }
    
    function loadEmbeddedCache() {
        if (embeddedCacheData.length === 0) {
            return
        }
        
        try {
            var data = JSON.parse(embeddedCacheData)
            for (var user in data) {
                userBackgrounds[user] = data[user]
            }
            cacheLoaded = true
        } catch (e) {
            console.error("AccountsService: Failed to parse cache data:", e)
        }
    }
    
    function getUserBackground(username) {
        if (!username || username.length === 0) {
            return ""
        }
        
        if (userBackgrounds.hasOwnProperty(username)) {
            return userBackgrounds[username]
        }
        
        return ""
    }
}
EOF

# Replace placeholder with actual escaped cache data
sed -i "s|CACHE_DATA_PLACEHOLDER|$CACHE_ESCAPED|g" "$QML_FILE"

echo "SDDM backgrounds cache updated successfully"
echo "Cache file: $CACHE_FILE"
echo "QML file: $QML_FILE"
